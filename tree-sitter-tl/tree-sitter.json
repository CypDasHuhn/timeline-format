{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "tl",
      "camelcase": "Tl",
      "title": "Timelog",
      "scope": "source.tl",
      "file-types": ["tl"],
      "injection-regex": "^tl$",
      "class-name": "TreeSitterTl"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the timelog (.tl) file format.",
    "authors": [
      {
        "name": "CypDasHuhn",
        "email": "Martinfischer533@gmail.com"
      }
    ]
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
