{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "tl",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "gct_block"
          },
          {
            "type": "SYMBOL",
            "name": "section"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          }
        ]
      }
    },
    "gct_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "```gct"
        },
        {
          "type": "SYMBOL",
          "name": "gct_content"
        },
        {
          "type": "STRING",
          "value": "```"
        }
      ]
    },
    "gct_content": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^`]*"
      }
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_header"
        },
        {
          "type": "STRING",
          "value": "---"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "entry"
              },
              {
                "type": "SYMBOL",
                "name": "comment"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "---"
        }
      ]
    },
    "section_header": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_name"
        },
        {
          "type": "STRING",
          "value": "|"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag_ref"
          }
        }
      ]
    },
    "section_name": {
      "type": "PATTERN",
      "value": "[^-/\\s|][^\\s|]*"
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "sub_marker"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_time_slot"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_duration_slot"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "tag_or_wildcard"
          }
        }
      ]
    },
    "sub_marker": {
      "type": "STRING",
      "value": "-"
    },
    "_time_slot": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "time"
        },
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "SYMBOL",
          "name": "percentage"
        }
      ]
    },
    "_duration_slot": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "duration"
        },
        {
          "type": "STRING",
          "value": "@"
        }
      ]
    },
    "tag_or_wildcard": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tag_ref"
        },
        {
          "type": "SYMBOL",
          "name": "wildcard"
        }
      ]
    },
    "wildcard": {
      "type": "STRING",
      "value": "_"
    },
    "tag_ref": {
      "type": "PATTERN",
      "value": "#[a-zA-Z][a-zA-Z0-9_-]*"
    },
    "time": {
      "type": "PATTERN",
      "value": "[0-9]{2}:[0-9]{2}"
    },
    "duration": {
      "type": "PATTERN",
      "value": "[0-9]+h[0-9]+m|[0-9]+h|[0-9]+min|[0-9]+m"
    },
    "percentage": {
      "type": "PATTERN",
      "value": "[0-9]+%"
    },
    "comment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "line_comment"
        },
        {
          "type": "SYMBOL",
          "name": "block_comment"
        }
      ]
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "\\/\\/[^\\n]*"
        }
      }
    },
    "block_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "/*"
          },
          {
            "type": "PATTERN",
            "value": "[^*]*\\*+([^/*][^*]*\\*+)*"
          },
          {
            "type": "STRING",
            "value": "/"
          }
        ]
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t\\n\\r]"
    }
  ],
  "conflicts": [
    [
      "entry",
      "entry"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}